<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@color/color_superficie"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/textoNombreProveedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_primario"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Químicos del Norte" />

    <TextView
        android:id="@+id/textoCorreoProveedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Correo: ventas@quimicosnorte.com" />

    <TextView
        android:id="@+id/textoTelefonoProveedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Teléfono: 2222-1111" />

    <TextView
        android:id="@+id/textoContactoProveedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Contacto: Carlos Vargas" />

    <!-- UI básica:
         Después podemos cambiar esto por iconos o cards más pro. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/botonVerDetalleProveedor"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:backgroundTint="@color/color_primario"
            android:text="Detalle"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonEditarProveedor"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:backgroundTint="@color/color_primario_medio"
            android:text="Editar"
            android:textColor="@color/blanco" />

    </LinearLayout>

</LinearLayout>