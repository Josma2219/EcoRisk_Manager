<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_primario_claro"
    android:orientation="vertical"
    tools:context=".ui.reportes.ReporteMaterialesRiesgoActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_encabezado_login"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botonVolver"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-12dp"
            android:text="‹ Volver"
            android:textColor="@color/color_primario_claro" />

        <TextView
            android:id="@+id/textoTituloReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Materiales por riesgo"
            android:textColor="@color/blanco"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoDescripcionReporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Filtra los materiales peligrosos por su clasificación de riesgo"
            android:textColor="@color/color_primario_claro"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/color_superficie"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <Spinner
                    android:id="@+id/spinnerRiesgo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_campo_generico"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/botonGenerarReporte"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/color_secundario"
                    android:text="Generar reporte"
                    android:textColor="@color/blanco"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/botonVerTodos"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:text="Ver todos los materiales"
                    android:textColor="@color/color_primario"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/color_primario" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/botonExportarPdf"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:text="Exportar PDF"
                    android:textColor="@color/color_primario_medio"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/color_primario_medio" />

                <TextView
                    android:id="@+id/textoEstadoPdf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="PDF: sin generar"
                    android:textColor="@color/texto_secundario"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/textoTotalMateriales"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Total en reporte: 0"
            android:textColor="@color/texto_primario"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoListaVacia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="No hay materiales para este reporte"
            android:textColor="@color/texto_primario"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMaterialesReporte"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            tools:listitem="@layout/item_reporte_material" />

    </LinearLayout>

</LinearLayout>