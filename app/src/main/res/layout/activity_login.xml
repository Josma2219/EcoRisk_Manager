<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    android:padding="24dp"
    tools:context=".ui.login.LoginActivity">

    <TextView
        android:id="@+id/textoTituloLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/titulo_login"
        android:textColor="@color/texto_primario"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/textoSubtituloLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/textoSubtituloLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/subtitulo_login"
        android:textColor="@color/texto_secundario"
        android:textSize="15sp"
        app:layout_constraintBottom_toTopOf="@id/campoUsuario"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textoTituloLogin" />

    <EditText
        android:id="@+id/campoUsuario"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="32dp"
        android:background="@color/color_superficie"
        android:hint="@string/campo_usuario"
        android:inputType="text"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/texto_primario"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintBottom_toTopOf="@id/campoContrasena"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textoSubtituloLogin" />

    <EditText
        android:id="@+id/campoContrasena"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="12dp"
        android:background="@color/color_superficie"
        android:hint="@string/campo_contrasena"
        android:inputType="textPassword"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/texto_primario"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintBottom_toTopOf="@id/botonEntrar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/campoUsuario" />

    <Button
        android:id="@+id/botonEntrar"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="22dp"
        android:backgroundTint="@color/color_primario"
        android:text="@string/accion_entrar"
        android:textColor="@color/blanco"
        app:layout_constraintBottom_toTopOf="@id/progresoLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/campoContrasena" />

    <ProgressBar
        android:id="@+id/progresoLogin"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="18dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/textoAyudaLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/botonEntrar" />

    <!-- Texto temporal para que el profe/equipo pueda probar fácil.
         Cuando la app ya esté más pulida, si quieren lo quitamos. -->
    <TextView
        android:id="@+id/textoAyudaLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Usuario de prueba: admin / admin123"
        android:textColor="@color/texto_secundario"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progresoLogin" />

</androidx.constraintlayout.widget.ConstraintLayout>