<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    tools:context=".ui.reportes.ReporteMenuActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textoTituloReportes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reportes"
            android:textColor="@color/texto_primario"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoDescripcionReportes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Consultas rápidas para apoyar el control de riesgos."
            android:textColor="@color/texto_secundario"
            android:textSize="15sp" />

        <!-- Estos botones luego abren pantallas reales de reportes. -->
        <Button
            android:id="@+id/botonReporteRiesgo"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/color_primario"
            android:text="Materiales por categoría de riesgo"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonReporteIncidentes"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/color_secundario"
            android:text="Historial de incidentes"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonVolver"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/color_primario_medio"
            android:text="Volver"
            android:textColor="@color/blanco" />

    </LinearLayout>

</ScrollView>