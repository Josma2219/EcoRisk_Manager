<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/color_superficie"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textoMaterialHoja"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/texto_primario"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Ácido Sulfúrico" />

            <TextView
                android:id="@+id/textoVersionHoja"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_chip"
                android:backgroundTint="@color/color_primario_medio"
                android:paddingStart="12dp"
                android:paddingTop="5dp"
                android:paddingEnd="12dp"
                android:paddingBottom="5dp"
                android:textColor="@color/blanco"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Versión: 1.0" />

        </LinearLayout>

        <TextView
            android:id="@+id/textoCodigoMaterial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp"
            tools:text="Código: MAT-001" />

        <TextView
            android:id="@+id/textoFechaEmision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp"
            tools:text="Fecha emisión: 2026-07-17" />

        <TextView
            android:id="@+id/textoArchivoPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp"
            tools:text="Archivo: hoja_acido.pdf" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botonDetalleHoja"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="Detalle"
                android:textColor="@color/color_primario"
                app:cornerRadius="10dp"
                app:strokeColor="@color/color_primario" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botonEditarHoja"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/color_primario_medio"
                android:text="Editar"
                android:textColor="@color/blanco"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>