<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@color/color_superficie"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/textoNombreMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_primario"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Ácido Sulfúrico" />

    <TextView
        android:id="@+id/textoCodigoMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Código: MAT-001" />

    <TextView
        android:id="@+id/textoRiesgoMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/color_secundario"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="Riesgo: Corrosivo" />

    <TextView
        android:id="@+id/textoEstadoMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Estado: Activo" />

    <TextView
        android:id="@+id/textoUnidadMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Unidad: Litros" />

</LinearLayout>