<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    tools:context=".ui.home.HomeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textoTituloHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_home"
            android:textColor="@color/texto_primario"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoDatosUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/texto_secundario"
            android:textSize="15sp"
            tools:text="Bienvenido Administrador - Rol: Administrador" />

        <!-- Dashboard básico.
             Luego estos números van a venir desde la base de datos. -->
        <LinearLayout
            android:id="@+id/contenedorDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tarjetaMateriales"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@color/color_superficie"
                android:gravity="center"
                android:text="0\nMateriales"
                android:textColor="@color/texto_primario"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tarjetaProveedores"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@color/color_superficie"
                android:gravity="center"
                android:text="0\nProveedores"
                android:textColor="@color/texto_primario"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textoSeccionModulos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Módulos"
            android:textColor="@color/texto_primario"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- UI básica: estos botones luego se pueden cambiar por cards más bonitas. -->
        <Button
            android:id="@+id/botonMateriales"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/color_primario"
            android:text="@string/modulo_materiales"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonHojas"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_primario_medio"
            android:text="@string/modulo_hojas"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonProveedores"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_primario_medio"
            android:text="@string/modulo_proveedores"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonMaterialProveedor"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_primario_medio"
            android:text="@string/modulo_material_proveedor"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonIncidentes"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_secundario"
            android:text="@string/modulo_incidentes"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonReportes"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_secundario"
            android:text="@string/modulo_reportes"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonRespaldo"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_secundario"
            android:text="@string/modulo_respaldo"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/riesgo_critico"
            android:text="@string/accion_cerrar_sesion"
            android:textColor="@color/blanco" />

    </LinearLayout>

</ScrollView>