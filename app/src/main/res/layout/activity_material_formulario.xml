<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    tools:context=".ui.materiales.MaterialFormularioActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textoTituloFormulario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar material"
            android:textColor="@color/texto_primario"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoDescripcionFormulario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Complete los datos básicos del material peligroso."
            android:textColor="@color/texto_secundario"
            android:textSize="15sp" />

        <!-- Después podemos cambiar estos EditText por TextInputLayout para que se vea más pro. -->
        <EditText
            android:id="@+id/campoCodigoMaterial"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:background="@color/color_superficie"
            android:hint="Código del material"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario" />

        <EditText
            android:id="@+id/campoNombreComercial"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_superficie"
            android:hint="Nombre comercial"
            android:inputType="textCapWords"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario" />

        <EditText
            android:id="@+id/campoDescripcion"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_superficie"
            android:gravity="top"
            android:hint="Descripción"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Clasificación de riesgo"
            android:textColor="@color/texto_primario"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerClasificacionRiesgo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@color/color_superficie" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Unidad de medida"
            android:textColor="@color/texto_primario"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerUnidadMedida"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@color/color_superficie" />

        <EditText
            android:id="@+id/campoFechaRegistro"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_superficie"
            android:hint="Fecha de registro"
            android:inputType="date"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario"
            tools:text="2026-07-17" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Estado"
            android:textColor="@color/texto_primario"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerEstado"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@color/color_superficie" />

        <Button
            android:id="@+id/botonGuardarMaterial"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/color_primario"
            android:text="Guardar"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonCancelar"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_secundario"
            android:text="Cancelar"
            android:textColor="@color/blanco" />

    </LinearLayout>

</ScrollView>