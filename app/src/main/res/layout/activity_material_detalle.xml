<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_primario_claro"
    android:orientation="vertical"
    tools:context=".ui.materiales.MaterialDetalleActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_encabezado_login"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botonVolver"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-12dp"
            android:text="‹ Volver"
            android:textColor="@color/color_primario_claro" />

        <TextView
            android:id="@+id/textoTituloDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Detalle del material"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_superficie"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/textoNombreComercial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/texto_primario"
                        android:textSize="23sp"
                        android:textStyle="bold"
                        tools:text="Ácido Sulfúrico" />

                    <TextView
                        android:id="@+id/textoClasificacionRiesgo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="6dp"
                        android:textColor="@color/blanco"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Clasificación: Corrosivo" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/color_borde_suave" />

                    <TextView
                        android:id="@+id/textoCodigoMaterial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/texto_secundario"
                        android:textSize="14sp"
                        tools:text="Código: MAT-001" />

                    <TextView
                        android:id="@+id/textoUnidadMedida"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/texto_secundario"
                        android:textSize="14sp"
                        tools:text="Unidad: Litros" />

                    <TextView
                        android:id="@+id/textoFechaRegistro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/texto_secundario"
                        android:textSize="14sp"
                        tools:text="Fecha de registro: 2026-07-17" />

                    <TextView
                        android:id="@+id/textoEstadoMaterial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/texto_secundario"
                        android:textSize="14sp"
                        tools:text="Estado: Activo" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/color_borde_suave" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Descripción"
                        android:textColor="@color/texto_primario"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textoDescripcionMaterial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.3"
                        android:textColor="@color/texto_primario"
                        android:textSize="14sp"
                        tools:text="Descripción completa del material peligroso." />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textoAccionesRelacionadas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Acciones relacionadas"
                android:textColor="@color/texto_primario"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botonEditarMaterial"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/color_secundario"
                android:text="Editar material"
                android:textColor="@color/blanco"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botonVerHojas"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/color_superficie"
                android:text="Ver hojas de seguridad"
                android:textColor="@color/color_primario_medio"
                app:cornerRadius="12dp"
                app:strokeColor="@color/color_primario_medio" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botonVerProveedores"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/color_superficie"
                android:text="Ver proveedores asociados"
                android:textColor="@color/color_primario"
                app:cornerRadius="12dp"
                app:strokeColor="@color/color_primario" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botonVerIncidentes"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/color_superficie"
                android:text="Ver incidentes del material"
                android:textColor="@color/color_primario"
                app:cornerRadius="12dp"
                app:strokeColor="@color/color_primario" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>