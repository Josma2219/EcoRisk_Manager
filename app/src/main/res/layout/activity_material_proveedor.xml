<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".ui.materialproveedor.MaterialProveedorActivity">

    <TextView
        android:id="@+id/textoTituloModulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Material por proveedor"
        android:textColor="@color/texto_primario"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textoDescripcionModulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Asocie proveedores con materiales peligrosos."
        android:textColor="@color/texto_secundario"
        android:textSize="15sp" />

    <!-- Formulario básico.
         Después podemos esconder esta zona cuando se entra solo a consultar desde detalle. -->
    <TextView
        android:id="@+id/textoMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Material"
        android:textColor="@color/texto_primario"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerMaterial"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="6dp"
        android:background="@color/color_superficie" />

    <TextView
        android:id="@+id/textoProveedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Proveedor"
        android:textColor="@color/texto_primario"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerProveedor"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="6dp"
        android:background="@color/color_superficie" />

    <EditText
        android:id="@+id/campoPrecioReferencia"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@color/color_superficie"
        android:hint="Precio de referencia"
        android:inputType="numberDecimal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/texto_primario"
        android:textColorHint="@color/texto_secundario" />

    <Button
        android:id="@+id/botonAsociar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/color_primario"
        android:text="Asociar material y proveedor"
        android:textColor="@color/blanco" />

    <TextView
        android:id="@+id/textoTituloLista"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Relaciones registradas"
        android:textColor="@color/texto_primario"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textoListaVacia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="No hay relaciones registradas"
        android:textColor="@color/texto_secundario"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRelaciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_material_proveedor" />

    <Button
        android:id="@+id/botonVolver"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/color_secundario"
        android:text="Volver"
        android:textColor="@color/blanco" />

</LinearLayout>