<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    tools:context=".ui.materialproveedor.MaterialProveedorActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textoTituloModulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/texto_primario"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:text="Material por proveedor" />

        <TextView
            android:id="@+id/textoDescripcionModulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/texto_secundario"
            android:textSize="15sp"
            tools:text="Descripción del módulo" />

        <!-- Luego aquí van los Spinners de material/proveedor y el precio. -->
        <TextView
            android:id="@+id/textoEstadoModulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@color/color_superficie"
            android:padding="18dp"
            android:textColor="@color/texto_primario"
            android:textSize="16sp"
            tools:text="Pendiente de desarrollo" />

        <Button
            android:id="@+id/botonVolver"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/color_primario"
            android:text="Volver"
            android:textColor="@color/blanco" />

    </LinearLayout>

</ScrollView>