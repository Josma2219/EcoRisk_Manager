<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_primario_claro"
    android:orientation="vertical"
    tools:context=".ui.hojas.HojaListaActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_encabezado_login"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botonVolver"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-12dp"
            android:text="‹ Volver"
            android:textColor="@color/color_primario_claro" />

        <TextView
            android:id="@+id/textoTituloModulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Hojas de seguridad"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoDescripcionModulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Registro y consulta de hojas de seguridad asociadas a materiales"
            android:textColor="@color/color_primario_claro"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botonAgregarHoja"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/color_secundario"
            android:text="+  Agregar hoja de seguridad"
            android:textColor="@color/blanco"
            app:cornerRadius="12dp" />

        <TextView
            android:id="@+id/textoListaVacia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="No hay hojas de seguridad registradas"
            android:textColor="@color/texto_primario"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHojas"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            tools:listitem="@layout/item_hoja_seguridad" />

    </LinearLayout>

</LinearLayout>