<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    tools:context=".ui.hojas.HojaFormularioActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textoTituloFormulario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar hoja"
            android:textColor="@color/texto_primario"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoDescripcionFormulario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Complete la información de la hoja de seguridad."
            android:textColor="@color/texto_secundario"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textoMaterial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Material asociado"
            android:textColor="@color/texto_primario"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerMaterial"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@color/color_superficie" />

        <EditText
            android:id="@+id/campoVersion"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_superficie"
            android:hint="Versión"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario" />

        <EditText
            android:id="@+id/campoFechaEmision"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_superficie"
            android:hint="Fecha de emisión"
            android:inputType="date"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario"
            tools:text="2026-07-17" />

        <EditText
            android:id="@+id/campoArchivoPdf"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_superficie"
            android:hint="Nombre del archivo PDF"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario" />

        <EditText
            android:id="@+id/campoObservaciones"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_superficie"
            android:gravity="top"
            android:hint="Observaciones"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/texto_primario"
            android:textColorHint="@color/texto_secundario" />

        <Button
            android:id="@+id/botonGuardarHoja"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/color_primario"
            android:text="Guardar"
            android:textColor="@color/blanco" />

        <Button
            android:id="@+id/botonCancelar"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/color_secundario"
            android:text="Cancelar"
            android:textColor="@color/blanco" />

    </LinearLayout>

</ScrollView>