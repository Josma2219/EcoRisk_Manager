<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@color/color_superficie"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/textoNombreMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_primario"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Ácido Sulfúrico" />

    <TextView
        android:id="@+id/textoCodigoMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Código: MAT-001" />

    <TextView
        android:id="@+id/textoRiesgoMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Riesgo: Corrosivo" />

    <TextView
        android:id="@+id/textoProveedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/texto_primario"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="Proveedor: Químicos del Norte" />

    <TextView
        android:id="@+id/textoCorreoProveedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/texto_secundario"
        android:textSize="14sp"
        tools:text="Correo: ventas@quimicosnorte.com" />

    <TextView
        android:id="@+id/textoPrecioReferencia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/color_secundario"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="Precio referencia: ₡15000.0" />

    <!-- UI básica:
         Luego podemos cambiar esto por icono de basurero o menú de acciones. -->
    <Button
        android:id="@+id/botonEliminarRelacion"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/riesgo_critico"
        android:text="Eliminar relación"
        android:textColor="@color/blanco" />

</LinearLayout>